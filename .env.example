# =============================================================================
# SONG (Secure Open Network Gateway) - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values before running the server.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SONG_HOST=0.0.0.0
SONG_PORT=8080
SONG_ENV=development  # Options: development, production, test

# -----------------------------------------------------------------------------
# Core Storage (JSON Files)
# -----------------------------------------------------------------------------
# The core directory stores users, functions, sessions, and logs.
# WARNING: This directory MUST NOT be served by the web server.
CORE_DIR=./core
CORE_BACKUP_ENABLED=true
CORE_BACKUP_INTERVAL=24h
CORE_FILE_LOCK_TIMEOUT=5s

# -----------------------------------------------------------------------------
# Authentication & Authorization
# -----------------------------------------------------------------------------
# Generate a strong random string (at least 32 characters) for production.
JWT_SECRET=change_me_to_a_secure_random_string_32_chars_long

# OIDC Configuration (Optional)
OIDC_ENABLED=false
OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret

# -----------------------------------------------------------------------------
# File System Paths
# -----------------------------------------------------------------------------
STATIC_DIR=./static
TEMPLATE_DIR=./templates
FUNCTIONS_DIR=./functions
DATA_DIR=./data

# -----------------------------------------------------------------------------
# Security Limits
# -----------------------------------------------------------------------------
MAX_FUNCTION_TIMEOUT=30s
MAX_MEMORY_MB=256
MAX_CPU_PERCENT=50

# -----------------------------------------------------------------------------
# Database Configuration (Optional)
# -----------------------------------------------------------------------------
# Set to 'false' to run SONG with only JSON core storage (no external DBs).
DB_ENABLED=false

# Default Database (Required if DB_ENABLED=true)
DB_DEFAULT_TYPE=postgresql
DB_DEFAULT_HOST=localhost
DB_DEFAULT_PORT=5432
DB_DEFAULT_USER=song_user
DB_DEFAULT_PASSWORD=secure_password
DB_DEFAULT_NAME=song_db
DB_DEFAULT_SSL_MODE=disable
DB_DEFAULT_MAX_CONNS=25
DB_DEFAULT_MIN_CONNS=5

# Additional Databases (Comma-separated list of names)
# Example: analytics,reports,cache
DB_ADDITIONAL_NAMES=

# Example Configuration for an Additional Database (Uncomment and modify)
# DB_ANALYTICS_TYPE=postgresql
# DB_ANALYTICS_HOST=analytics-db.internal
# DB_ANALYTICS_PORT=5432
# DB_ANALYTICS_USER=analytics_user
# DB_ANALYTICS_PASSWORD=analytics_secret
# DB_ANALYTICS_NAME=analytics_db

# Example Configuration for a Redis Cache (Uncomment and modify)
# DB_CACHE_TYPE=redis
# DB_CACHE_HOST=redis.internal
# DB_CACHE_PORT=6379
# DB_CACHE_PASSWORD=redis_secret
# DB_CACHE_DB=0